{
  "manifest_version": 3,
  "name": "Tab Audio Recorder",
  "version": "1.0.0",
  "description": "Capture audio/video from browser tabs and save as MP3/WebM for English learning",
  "permissions": ["tabCapture", "activeTab", "offscreen", "storage", "downloads"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
